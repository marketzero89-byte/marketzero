# PBT Trading Platform — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── Alpaca API ─────────────────────────────────────────────────────────────
# Standard Alpaca SDK env var names (used by AlpacaBroker)
APCA_API_KEY_ID=your_alpaca_key_here
APCA_API_SECRET_KEY=your_alpaca_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
ALPACA_PAPER=true

# ── Dashboard security (optional) ───────────────────────────────────────────
# Set PBT_API_KEY to require X-API-Key header on /api/* and ?api_key= on /ws
PBT_API_KEY=
PBT_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Alert: Email (optional) ───────────────────────────────────────────────
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASS=

# ── Alert: Slack (optional) ───────────────────────────────────────────────
ALERT_SLACK_WEBHOOK=

# ── MLflow / W&B (optional) ───────────────────────────────────────────────
MLFLOW_TRACKING_URI=
WANDB_API_KEY=

# ── CoinGlass API ─────────────────────────────────────────────────────────
# Get your key at: https://www.coinglass.com/pricing
# Used by CoinGlassBroker (--broker coinglass) for real-time crypto data.
# Provides: price, open interest, funding rates, liquidations for BTC/ETH/SOL+
# Auth: single API key sent as CG-API-KEY header (no secret required).
# Base URL: https://open-api-v4.coinglass.com
COINGLASS_API_KEY=your_coinglass_key_here
